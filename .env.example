# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn session cookies (JSON array from browser DevTools → Application → Cookies)
# Required for LinkedIn scraping. Export after logging in manually.
LINKEDIN_COOKIES=[]

# Glassdoor session cookies (optional — scrapes preview text without login)
GLASSDOOR_COOKIES=[]
