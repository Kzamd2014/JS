# IMPORTANT: after copying this file to .env, run: chmod 600 .env
# It contains session cookies that grant full account access.

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# SerpAPI key — get one at serpapi.com (free tier: 100 searches/month)
# Required for Google Jobs scraping
SERPAPI_KEY=

# LinkedIn session cookies (JSON array from browser DevTools → Application → Cookies)
# Required for LinkedIn scraping. Export after logging in manually.
LINKEDIN_COOKIES=

# Glassdoor session cookies (optional — scrapes preview text without login)
GLASSDOOR_COOKIES=

# Failure email notifications (optional)
# NOTIFY_EMAIL: the Gmail address to send failure alerts to
# GMAIL_APP_PASSWORD: generate at myaccount.google.com → Security → App passwords
NOTIFY_EMAIL=
GMAIL_APP_PASSWORD=
